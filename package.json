{
	"name": "pi-session-move",
	"version": "0.1.0",
	"private": false,
	"description": "Pi extension that moves the current session context to another working directory without invoking the LLM.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"move",
		"session"
	],
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.3",
		"typebox": "latest"
	},
	"pi": {
		"extensions": [
			"index.ts"
		]
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"tsx": "^4.22.4"
	},
	"scripts": {
		"lineages": "tsx scripts/list-lineage-resume.ts",
		"migrate-paths": "tsx scripts/migrate-session-move-paths.ts",
		"migrate-paths:move": "tsx scripts/migrate-session-move-paths.ts --move"
	},
	"bin": {
		"pil": "./bin/pi-session-lineages.js"
	},
	"files": [
		"index.ts",
		"README.md",
		"bin",
		"scripts",
		"tsconfig.json"
	]
}
