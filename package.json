{
	"name": "pi-session-move",
	"version": "0.1.1",
	"private": false,
	"description": "Pi extension that moves the current session context to another working directory without invoking the LLM.",
	"type": "module",
	"keywords": [
		"pi-package",
		"pi-extension",
		"move",
		"session"
	],
	"dependencies": {
		"@earendil-works/pi-coding-agent": "^0.75.3",
		"typebox": "latest"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"tsx": "^4.22.4"
	},
	"scripts": {
		"lineages": "tsx scripts/list-lineage-resume.ts",
		"migrate-paths": "tsx scripts/migrate-session-move-paths.ts",
		"migrate-paths:move": "tsx scripts/migrate-session-move-paths.ts --move",
		"build": "tsc --project tsconfig.json",
		"lint": "tsc --noEmit"
	},
	"bin": {
		"pil": "dist/scripts/list-lineage-resume.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"tsconfig.json"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts"
}
